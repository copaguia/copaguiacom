rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Utilidad ---
    function estaAutenticado() {
      return request.auth != null;
    }

    // Verifica si el usuario tiene un rol específico (ej. 'admin').
    // Para que esto funcione, en tu colección 'Usuarios', cada documento de usuario
    // debe tener un mapa llamado 'roles' con el rol, por ejemplo: { roles: { admin: true } }
    function tieneRol(rol) {
      return estaAutenticado() && get(/databases/$(database)/documents/Usuarios/$(request.auth.uid)).data.roles[rol] == true;
    }


    // --- Colecciones ---

    // Colección 'Usuarios': Perfiles públicos de usuario
    match /Usuarios/{uid} {
      // Cualquiera puede leer perfiles
      allow read: if true;
      // El dueño del perfil o un admin pueden escribir
      allow write: if estaAutenticado() && (request.auth.uid == uid || tieneRol('admin'));
    }

    // Colección 'negocios'
    match /negocios/{negocioId} {
      // Lectura pública para todos
      allow read: if true;

      // Se divide la regla de 'write' en create, update, delete para mayor control.
      
      // CREAR: Solo los administradores pueden crear nuevos negocios.
      // Esto resuelve el error de permisos que estabas viendo.
      allow create: if tieneRol('admin');

      // ACTUALIZAR: El dueño del negocio (duenoId) o un admin pueden actualizar.
      allow update: if estaAutenticado() && (request.auth.uid == resource.data.duenoId || tieneRol('admin'));

      // BORRAR: Solo los administradores pueden borrar.
      allow delete: if tieneRol('admin');

      // Subcolección 'pedidos'
      match /pedidos/{pedidoId} {
        allow create: if true; // Cualquiera puede crear un pedido
        // El dueño del negocio o un admin pueden leer/actualizar pedidos
        allow read, update: if estaAutenticado() &&
          (request.auth.uid == get(/databases/$(database)/documents/negocios/$(negocioId)).data.duenoId || tieneRol('admin'));
        // Solo admins pueden borrar pedidos
        allow delete: if tieneRol('admin');
      }
    }
  }
}
