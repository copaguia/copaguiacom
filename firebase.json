{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist/myapp/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "apphosting": {
      "port": 5002,
      "host": "127.0.0.1",
      "rootDirectory": "./",
      "startCommand": "npm run start"
    },
    "auth": {
      "port": 9100,
      "host": "127.0.0.1"
    },
    "functions": {
      "port": 5001,"host": "127.0.0.1"
    },
    "firestore": {
      "port": 8081,
      "host": "127.0.0.1"
    },
    "hosting": {
      "port": 5002,
       "host": "127.0.0.1"
    },
    "storage": {
      "port": 9200,
      "host": "127.0.0.1"
    },
    "ui": {
      "enabled": true, "port": 4000, "host": "127.0.0.1"
    },
      "logging": {
        "port": 4500,
        "host": "127.0.0.1"
      },
       "hub": {
        "port": 4400,
        "host": "127.0.0.1"
    },
    "singleProjectMode": true
  }
}
